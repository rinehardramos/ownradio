DATABASE_URL=changeme
JWT_SECRET=changeme
GOOGLE_CLIENT_ID=your-value-here
GOOGLE_CLIENT_SECRET=your-value-here
NEXT_PUBLIC_API_URL=your-value-here
NEXT_PUBLIC_WS_URL=your-value-here

# PlayGen webhook authentication — must match PLAYGEN_WEBHOOK_SECRET on the PlayGen DJ service
